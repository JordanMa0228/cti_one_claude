<?xml version="1.0" ?>
<!--
  Living room world for W102 path-planning simulation.
  Room: 10 ft × 12 ft  →  3.048 m × 3.658 m
  Coordinate system: X = east, Y = north, Z = up
  Robot start: (0, 0) m  |  Chair: (0, 1.219) m  |  John: (0, 3.048) m
-->
<sdf version="1.9">
  <world name="living_room">

    <!-- ===== GUI camera — angled view showing the full right-side path ===== -->
    <!--
      Camera at (4, -1.5, 4) looking toward room centre.
      Pitch 0.75 rad (~43°) down, Yaw 2.5 rad to face the action.
    -->
    <gui fullscreen="0">
      <plugin filename="MinimalScene" name="3D View">
        <gz-gui>
          <title>W102 Living Room</title>
          <property type="bool"   key="showTitleBar">false</property>
          <property type="string" key="state">docked</property>
        </gz-gui>
        <engine>ogre</engine>
        <scene>scene</scene>
        <ambient_light>0.5 0.5 0.5</ambient_light>
        <background_color>0.55 0.73 0.87</background_color>
        <!-- Camera framed on the right-side path S→R1→R2→G -->
        <camera_pose>0 1.5 7 0 1.5708 0</camera_pose>
        <camera_clip><near>0.1</near><far>100</far></camera_clip>
      </plugin>

      <plugin filename="GzSceneManager" name="Scene Manager">
        <gz-gui>
          <property key="resizable"     type="bool">false</property>
          <property key="height"        type="double">5</property>
          <property key="width"         type="double">5</property>
          <property key="state"         type="string">floating</property>
          <property key="showTitleBar"  type="bool">false</property>
        </gz-gui>
      </plugin>

      <plugin filename="InteractiveViewControl" name="Interactive view control">
        <gz-gui>
          <property key="resizable"    type="bool">false</property>
          <property key="state"        type="string">floating</property>
          <property key="showTitleBar" type="bool">false</property>
        </gz-gui>
      </plugin>

      <plugin filename="EntityTree" name="Entity tree">
        <gz-gui>
          <property key="state"        type="string">docked_collapsed</property>
          <property key="showTitleBar" type="bool">true</property>
        </gz-gui>
      </plugin>

      <plugin filename="WorldControl" name="World control">
        <gz-gui>
          <title>World control</title>
          <property type="bool"   key="showTitleBar">false</property>
          <property type="string" key="state">floating</property>
          <property type="double" key="width">150</property>
          <property type="double" key="height">50</property>
          <property type="double" key="z">1</property>
        </gz-gui>
        <play_pause>true</play_pause>
        <step>true</step>
        <start_paused>false</start_paused>
      </plugin>

      <plugin filename="WorldStats" name="World stats">
        <gz-gui>
          <title>World stats</title>
          <property type="bool"   key="showTitleBar">false</property>
          <property type="string" key="state">floating</property>
          <property type="double" key="width">280</property>
          <property type="double" key="height">110</property>
          <property type="double" key="z">1</property>
        </gz-gui>
        <sim_time>true</sim_time>
        <real_time>true</real_time>
        <real_time_factor>true</real_time_factor>
        <iterations>true</iterations>
      </plugin>
    </gui>

    <!-- ===== Physics ===== -->
    <physics name="default_physics" type="dart">
      <max_step_size>0.002</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <!-- ===== Required world plugins ===== -->
    <plugin filename="gz-sim-physics-system"
            name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-scene-broadcaster-system"
            name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-user-commands-system"
            name="gz::sim::systems::UserCommands"/>

    <!-- ===== Lighting ===== -->
    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>1.0 0.98 0.9 1</diffuse>
      <specular>0.3 0.3 0.3 1</specular>
      <direction>-0.4 0.2 -0.9</direction>
    </light>

    <light type="point" name="room_lamp">
      <pose>0 1.829 2.2 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.1 0.1 0.1 1</specular>
      <attenuation>
        <range>10</range>
        <constant>0.4</constant>
        <linear>0.05</linear>
        <quadratic>0.01</quadratic>
      </attenuation>
      <cast_shadows>false</cast_shadows>
    </light>

    <!-- ===== Floor ===== -->
    <model name="floor">
      <static>true</static>
      <pose>0 1.829 0 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry>
            <box><size>3.048 3.658 0.05</size></box>
          </geometry>
          <surface>
            <friction><ode><mu>0.8</mu><mu2>0.8</mu2></ode></friction>
          </surface>
        </collision>
        <visual name="vis">
          <pose>0 0 -0.025 0 0 0</pose>
          <geometry>
            <box><size>3.048 3.658 0.05</size></box>
          </geometry>
          <material>
            <ambient>0.76 0.60 0.42 1</ambient>
            <diffuse>0.76 0.60 0.42 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- ===== Walls (thickness 0.12 m, height 2.5 m) ===== -->
    <!-- South wall  y = -0.06 -->
    <model name="wall_south">
      <static>true</static>
      <pose>0 -0.06 1.25 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>3.288 0.12 2.5</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>3.288 0.12 2.5</size></box></geometry>
          <material><ambient>0.92 0.90 0.85 1</ambient><diffuse>0.92 0.90 0.85 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- North wall  y = 3.718 -->
    <model name="wall_north">
      <static>true</static>
      <pose>0 3.718 1.25 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>3.288 0.12 2.5</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>3.288 0.12 2.5</size></box></geometry>
          <material><ambient>0.92 0.90 0.85 1</ambient><diffuse>0.92 0.90 0.85 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- West wall  x = -1.584 -->
    <model name="wall_west">
      <static>true</static>
      <pose>-1.584 1.829 1.25 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.12 3.898 2.5</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>0.12 3.898 2.5</size></box></geometry>
          <material><ambient>0.88 0.86 0.80 1</ambient><diffuse>0.88 0.86 0.80 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- East wall  x = 1.584 -->
    <model name="wall_east">
      <static>true</static>
      <pose>1.584 1.829 1.25 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.12 3.898 2.5</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>0.12 3.898 2.5</size></box></geometry>
          <material><ambient>0.88 0.86 0.80 1</ambient><diffuse>0.88 0.86 0.80 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- ===== Chair obstacle  (0, 1.219 m) ===== -->
    <!-- Seat -->
    <model name="chair">
      <static>true</static>
      <pose>0 1.219 0 0 0 0</pose>
      <link name="seat">
        <pose>0 0 0.45 0 0 0</pose>
        <collision name="col"><geometry><box><size>0.5 0.5 0.05</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>0.5 0.5 0.05</size></box></geometry>
          <material><ambient>0.40 0.25 0.10 1</ambient><diffuse>0.40 0.25 0.10 1</diffuse></material>
        </visual>
      </link>
      <!-- Backrest -->
      <link name="back">
        <pose>0 -0.225 0.75 0 0 0</pose>
        <collision name="col"><geometry><box><size>0.5 0.05 0.55</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>0.5 0.05 0.55</size></box></geometry>
          <material><ambient>0.40 0.25 0.10 1</ambient><diffuse>0.40 0.25 0.10 1</diffuse></material>
        </visual>
      </link>
      <!-- Four legs -->
      <link name="leg_fl">
        <pose> 0.21  0.21 0.225 0 0 0</pose>
        <collision name="col"><geometry><box><size>0.04 0.04 0.45</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>0.04 0.04 0.45</size></box></geometry>
          <material><ambient>0.30 0.18 0.08 1</ambient><diffuse>0.30 0.18 0.08 1</diffuse></material>
        </visual>
      </link>
      <link name="leg_fr">
        <pose>-0.21  0.21 0.225 0 0 0</pose>
        <collision name="col"><geometry><box><size>0.04 0.04 0.45</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>0.04 0.04 0.45</size></box></geometry>
          <material><ambient>0.30 0.18 0.08 1</ambient><diffuse>0.30 0.18 0.08 1</diffuse></material>
        </visual>
      </link>
      <link name="leg_bl">
        <pose> 0.21 -0.21 0.225 0 0 0</pose>
        <collision name="col"><geometry><box><size>0.04 0.04 0.45</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>0.04 0.04 0.45</size></box></geometry>
          <material><ambient>0.30 0.18 0.08 1</ambient><diffuse>0.30 0.18 0.08 1</diffuse></material>
        </visual>
      </link>
      <link name="leg_br">
        <pose>-0.21 -0.21 0.225 0 0 0</pose>
        <collision name="col"><geometry><box><size>0.04 0.04 0.45</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>0.04 0.04 0.45</size></box></geometry>
          <material><ambient>0.30 0.18 0.08 1</ambient><diffuse>0.30 0.18 0.08 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- ===== John marker  (0, 3.048 m) ===== -->
    <model name="john_marker">
      <static>true</static>
      <pose>0 3.048 0 0 0 0</pose>
      <link name="body">
        <!-- Torso -->
        <pose>0 0 1.0 0 0 0</pose>
        <collision name="col"><geometry><box><size>0.4 0.25 0.7</size></box></geometry></collision>
        <visual name="torso_vis">
          <geometry><box><size>0.4 0.25 0.7</size></box></geometry>
          <material><ambient>0.2 0.4 0.8 1</ambient><diffuse>0.2 0.4 0.8 1</diffuse></material>
        </visual>
      </link>
      <link name="head">
        <pose>0 0 1.55 0 0 0</pose>
        <collision name="col"><geometry><sphere><radius>0.12</radius></sphere></geometry></collision>
        <visual name="head_vis">
          <geometry><sphere><radius>0.12</radius></sphere></geometry>
          <material><ambient>0.9 0.75 0.6 1</ambient><diffuse>0.9 0.75 0.6 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- ===== Graph waypoint markers (visual only) ===== -->
    <model name="wp_R1">
      <static>true</static>
      <pose>0.9144 0 0.02 0 0 0</pose>
      <link name="link">
        <visual name="vis">
          <geometry><cylinder><radius>0.06</radius><length>0.04</length></cylinder></geometry>
          <material><ambient>0 0.7 1 1</ambient><diffuse>0 0.7 1 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="wp_R2">
      <static>true</static>
      <pose>0.9144 1.8288 0.02 0 0 0</pose>
      <link name="link">
        <visual name="vis">
          <geometry><cylinder><radius>0.06</radius><length>0.04</length></cylinder></geometry>
          <material><ambient>0 0.7 1 1</ambient><diffuse>0 0.7 1 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="wp_L1">
      <static>true</static>
      <pose>-0.9144 0 0.02 0 0 0</pose>
      <link name="link">
        <visual name="vis">
          <geometry><cylinder><radius>0.06</radius><length>0.04</length></cylinder></geometry>
          <material><ambient>0.5 0.5 0.5 1</ambient><diffuse>0.5 0.5 0.5 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="wp_L2">
      <static>true</static>
      <pose>-0.9144 1.8288 0.02 0 0 0</pose>
      <link name="link">
        <visual name="vis">
          <geometry><cylinder><radius>0.06</radius><length>0.04</length></cylinder></geometry>
          <material><ambient>0.5 0.5 0.5 1</ambient><diffuse>0.5 0.5 0.5 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- ===== W102 Robot ===== -->
    <!--
      Base footprint: 0.686 m × 0.813 m (27 in × 32 in)
      Drive wheels:   radius 0.10 m, separation 0.54 m
      Caster wheel:   radius 0.05 m at front
      Initial pose:   (0, 0.3) m, facing +Y (yaw = π/2)
    -->
    <model name="w102">
      <pose>0 0.3 0.12 0 0 1.5708</pose>

      <!-- Base link -->
      <link name="base_link">
        <inertial>
          <mass>15.0</mass>
          <inertia>
            <ixx>0.35</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>0.50</iyy><iyz>0</iyz>
            <izz>0.65</izz>
          </inertia>
        </inertial>
        <collision name="base_col">
          <geometry><box><size>0.686 0.813 0.20</size></box></geometry>
        </collision>
        <visual name="base_vis">
          <geometry><box><size>0.686 0.813 0.20</size></box></geometry>
          <material>
            <ambient>0.15 0.15 0.15 1</ambient>
            <diffuse>0.15 0.15 0.15 1</diffuse>
            <specular>0.4 0.4 0.4 1</specular>
          </material>
        </visual>
        <!-- Sensor tower -->
        <visual name="tower_vis">
          <pose>0 0.1 0.18 0 0 0</pose>
          <geometry><cylinder><radius>0.06</radius><length>0.16</length></cylinder></geometry>
          <material><ambient>0.8 0.2 0.0 1</ambient><diffuse>0.8 0.2 0.0 1</diffuse></material>
        </visual>
        <!-- Front bumper stripe -->
        <visual name="bumper_vis">
          <pose>0 0.41 -0.05 0 0 0</pose>
          <geometry><box><size>0.686 0.02 0.08</size></box></geometry>
          <material><ambient>1.0 0.5 0.0 1</ambient><diffuse>1.0 0.5 0.0 1</diffuse></material>
        </visual>
      </link>

      <!-- Left drive wheel -->
      <link name="left_wheel">
        <pose>-0.27 0 -0.02 1.5708 0 0</pose>
        <inertial>
          <mass>1.5</mass>
          <inertia><ixx>0.0045</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.0045</iyy><iyz>0</iyz><izz>0.0075</izz></inertia>
        </inertial>
        <collision name="col">
          <geometry><cylinder><radius>0.10</radius><length>0.05</length></cylinder></geometry>
          <surface><friction><ode><mu>1.0</mu><mu2>0.5</mu2></ode></friction></surface>
        </collision>
        <visual name="vis">
          <geometry><cylinder><radius>0.10</radius><length>0.05</length></cylinder></geometry>
          <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
        </visual>
      </link>

      <joint name="left_wheel_joint" type="revolute">
        <parent>base_link</parent>
        <child>left_wheel</child>
        <axis><xyz>0 0 1</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
      </joint>

      <!-- Right drive wheel -->
      <link name="right_wheel">
        <pose>0.27 0 -0.02 1.5708 0 0</pose>
        <inertial>
          <mass>1.5</mass>
          <inertia><ixx>0.0045</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.0045</iyy><iyz>0</iyz><izz>0.0075</izz></inertia>
        </inertial>
        <collision name="col">
          <geometry><cylinder><radius>0.10</radius><length>0.05</length></cylinder></geometry>
          <surface><friction><ode><mu>1.0</mu><mu2>0.5</mu2></ode></friction></surface>
        </collision>
        <visual name="vis">
          <geometry><cylinder><radius>0.10</radius><length>0.05</length></cylinder></geometry>
          <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
        </visual>
      </link>

      <joint name="right_wheel_joint" type="revolute">
        <parent>base_link</parent>
        <child>right_wheel</child>
        <axis><xyz>0 0 1</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
      </joint>

      <!-- Front caster wheel -->
      <link name="caster_wheel">
        <pose>0 0.36 -0.07 0 0 0</pose>
        <inertial>
          <mass>0.3</mass>
          <inertia><ixx>0.0003</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.0003</iyy><iyz>0</iyz><izz>0.0003</izz></inertia>
        </inertial>
        <collision name="col">
          <geometry><sphere><radius>0.05</radius></sphere></geometry>
          <surface><friction><ode><mu>0.0</mu><mu2>0.0</mu2></ode></friction></surface>
        </collision>
        <visual name="vis">
          <geometry><sphere><radius>0.05</radius></sphere></geometry>
          <material><ambient>0.3 0.3 0.3 1</ambient><diffuse>0.3 0.3 0.3 1</diffuse></material>
        </visual>
      </link>

      <joint name="caster_joint" type="ball">
        <parent>base_link</parent>
        <child>caster_wheel</child>
      </joint>

      <!-- Rear caster wheel -->
      <link name="caster_rear">
        <pose>0 -0.36 -0.07 0 0 0</pose>
        <inertial>
          <mass>0.3</mass>
          <inertia><ixx>0.0003</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.0003</iyy><iyz>0</iyz><izz>0.0003</izz></inertia>
        </inertial>
        <collision name="col">
          <geometry><sphere><radius>0.05</radius></sphere></geometry>
          <surface><friction><ode><mu>0.0</mu><mu2>0.0</mu2></ode></friction></surface>
        </collision>
        <visual name="vis">
          <geometry><sphere><radius>0.05</radius></sphere></geometry>
          <material><ambient>0.3 0.3 0.3 1</ambient><diffuse>0.3 0.3 0.3 1</diffuse></material>
        </visual>
      </link>

      <joint name="caster_rear_joint" type="ball">
        <parent>base_link</parent>
        <child>caster_rear</child>
      </joint>

      <!-- Differential drive plugin -->
      <plugin filename="gz-sim-diff-drive-system"
              name="gz::sim::systems::DiffDrive">
        <left_joint>left_wheel_joint</left_joint>
        <right_joint>right_wheel_joint</right_joint>
        <wheel_separation>0.54</wheel_separation>
        <wheel_radius>0.10</wheel_radius>
        <odom_publish_frequency>50</odom_publish_frequency>
        <topic>/cmd_vel</topic>
        <odom_topic>/odom</odom_topic>
        <frame_id>odom</frame_id>
        <child_frame_id>base_link</child_frame_id>
      </plugin>

      <!-- Joint state publisher -->
      <plugin filename="gz-sim-joint-state-publisher-system"
              name="gz::sim::systems::JointStatePublisher">
        <topic>/joint_states</topic>
      </plugin>

    </model>

  </world>
</sdf>
